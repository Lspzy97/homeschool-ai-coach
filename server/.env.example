# 微信支付配置（方案A：有商户号）
# 请复制此文件为 .env 并填入您的信息

# 商户号
WECHAT_MCH_ID=你的商户号

# 证书序列号（在微信支付商户平台获取）
WECHAT_SERIAL_NO=证书序列号

# 商户私钥文件路径（需要先上传证书到服务器）
WECHAT_PRIVATE_KEY=/path/to/apiclient_key.pem

# 商户API密钥（API v2密钥，用于部分接口兼容）
WECHAT_API_KEY=你的API密钥

# 微信应用ID（小程序appId）
WECHAT_APPID=wx1234567890abcdef

# 支付回调地址（需要是公网可访问的HTTPS地址）
WECHAT_NOTIFY_URL=https://你的域名/api/payment/callback

# 运行环境
NODE_ENV=development