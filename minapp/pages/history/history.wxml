<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-icon">
      <text>📋</text>
    </view>
    <text class="page-title">历史记录</text>
    <text class="page-subtitle">最近 {{history.length}} 条分析记录</text>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:if="{{history.length > 0}}">
    <view wx:for="{{history}}" wx:key="index" class="history-card" bindtap="viewDetail" data-item="{{item}}">
      <view class="card-left">
        <view class="history-tags">
          <view class="tag tag-orange">
            <text class="tag-icon">🎯</text>
            <text>{{item.qingzhiType}}</text>
          </view>
          <view class="tag tag-green">
            <text>{{item.mbtiType}}</text>
          </view>
          <view class="tag tag-blue">
            <text>{{item.recipientType}}</text>
          </view>
        </view>
        <text class="history-preview">{{item.replyOptions[0] || ''}}</text>
        <view class="history-meta">
          <text class="meta-time">{{formatTime(item.timestamp)}}</text>
          <text class="meta-name" wx:if="{{item.personName}}">· {{item.personName}}</text>
        </view>
      </view>
      <view class="card-right">
        <view class="arrow-icon">›</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-illustration">📋</view>
    <text class="empty-title">暂无历史记录</text>
    <text class="empty-desc">快去「分析」页面创建第一条记录吧</text>
  </view>

  <!-- 详情弹窗 -->
  <view class="detail-modal" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="modal-sheet" catchtap="">
      <!-- 弹窗头部 -->
      <view class="sheet-header">
        <text class="sheet-title">分析详情</text>
        <view class="sheet-close" bindtap="closeDetail">×</view>
      </view>

      <!-- 弹窗内容 -->
      <scroll-view class="sheet-body" scroll-y>
        <!-- 核心属性 -->
        <view class="section core-section">
          <view class="section-label-row">
            <text class="section-icon">🔍</text>
            <text class="section-label">属性分析</text>
          </view>
          <view class="attr-badges">
            <view class="attr-badge badge-orange">{{currentItem.qingzhiType}}</view>
            <view class="attr-badge badge-green">{{currentItem.mbtiType}}</view>
            <view class="attr-badge badge-blue">{{currentItem.recipientType || '家长'}}</view>
          </view>
          <view class="attr-desc-card">
            <text class="attr-desc">{{currentItem.qingzhiDesc}}</text>
            <text class="mbti-desc" wx:if="{{currentItem.mbtiDesc}}">{{currentItem.mbtiDesc}}</text>
          </view>
          <view class="psychology-hint" wx:if="{{currentItem.psychologyHint}}">
            <text class="hint-icon">💡</text>
            <text class="hint-text">{{currentItem.psychologyHint}}</text>
          </view>
        </view>

        <!-- 心理学维度 -->
        <view class="section">
          <view class="section-label-row">
            <text class="section-icon">🧠</text>
            <text class="section-label">心理学维度</text>
          </view>
          <view class="psychology-grid">
            <view class="psy-card" wx:if="{{currentItem.attachmentType}}">
              <text class="psy-label">依恋类型</text>
              <text class="psy-value">{{currentItem.attachmentType}}</text>
              <text class="psy-desc" wx:if="{{currentItem.attachmentDesc}}">{{currentItem.attachmentDesc}}</text>
            </view>
            <view class="psy-card" wx:if="{{currentItem.satirStance}}">
              <text class="psy-label">沟通姿态</text>
              <text class="psy-value">{{currentItem.satirStance}}</text>
              <text class="psy-desc" wx:if="{{currentItem.satirDesc}}">{{currentItem.satirDesc}}</text>
            </view>
            <view class="psy-card" wx:if="{{currentItem.bigFiveHint}}">
              <text class="psy-label">大五人格</text>
              <text class="psy-value">{{currentItem.bigFiveHint}}</text>
            </view>
            <view class="psy-card" wx:if="{{currentItem.learningStyleHint}}">
              <text class="psy-label">学习风格</text>
              <text class="psy-value">{{currentItem.learningStyleHint}}</text>
            </view>
            <view class="psy-card" wx:if="{{currentItem.eqLevel}}">
              <text class="psy-label">情商水平</text>
              <text class="psy-value">{{currentItem.eqLevel}}</text>
              <text class="psy-desc" wx:if="{{currentItem.eqDesc}}">{{currentItem.eqDesc}}</text>
            </view>
            <view class="psy-card" wx:if="{{currentItem.cognitiveBias}}">
              <text class="psy-label">认知偏差</text>
              <text class="psy-value">{{currentItem.cognitiveBias}}</text>
            </view>
            <view class="psy-card full" wx:if="{{currentItem.sdtNeed}}">
              <text class="psy-label">内在需求 SDT</text>
              <text class="psy-value">{{currentItem.sdtNeed}}</text>
            </view>
          </view>
        </view>

        <!-- 推荐回复 -->
        <view class="section" wx:if="{{currentItem.replyOptions && currentItem.replyOptions.length > 0}}">
          <view class="section-label-row">
            <text class="section-icon">💬</text>
            <text class="section-label">推荐回复</text>
          </view>
          <view class="reply-list">
            <view wx:for="{{currentItem.replyOptions}}" wx:key="index" class="reply-card">
              <view class="reply-header">
                <text class="reply-num">选项 {{index + 1}}</text>
              </view>
              <text class="reply-text">{{item}}</text>
              <view class="reply-copy" bindtap="copyText" data-text="{{item}}">
                <text>复制</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 预警提示 -->
        <view class="section warning-section" wx:if="{{currentItem.warning}}">
          <view class="warning-card">
            <text class="warning-icon">⚠️</text>
            <view class="warning-content">
              <text class="warning-title">温馨提示</text>
              <text class="warning-text">{{currentItem.warning}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>