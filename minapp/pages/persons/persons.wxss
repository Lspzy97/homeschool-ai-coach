/* ============================================
   人员管理页 - 暗夜琉璃
   ============================================ */

.container {
  min-height: 100vh;
  background: var(--bg-gradient);
  padding: var(--space-4);
}

/* ============================================
   页面头部
   ============================================ */

.page-header {
  text-align: center;
  padding: var(--space-4) 0 var(--space-5);
  position: relative;
}

.header-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto var(--space-3);
  background: linear-gradient(135deg, var(--primary-500) 0%, #EC4899 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: var(--shadow-glow);
}

.page-title {
  display: block;
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.page-subtitle {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--neutral-500);
}

/* ============================================
   统计卡片行 - 暗色玻璃
   ============================================ */

.stats-row {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}

.stat-card {
  flex: 1;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
}

.stat-card:nth-child(1)::before {
  background: linear-gradient(90deg, var(--primary-500), #EC4899);
}

.stat-card:nth-child(2)::before {
  background: linear-gradient(90deg, var(--secondary-500), #FB923C);
}

.stat-card:nth-child(3)::before {
  background: linear-gradient(90deg, #EC4899, #F093FB);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.stat-icon.blue {
  background: rgba(102, 126, 234, 0.25);
}

.stat-icon.green {
  background: rgba(245, 158, 11, 0.25);
}

.stat-icon.orange {
  background: rgba(236, 72, 153, 0.25);
}

.stat-info {
  flex: 1;
  min-width: 0;
}

.stat-num {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--neutral-500);
}

/* ============================================
   人员卡片列表 - 暗色玻璃
   ============================================ */

.persons-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.person-card {
  display: flex;
  align-items: center;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  position: relative;
  overflow: hidden;
}

.person-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.person-card::after {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  border-radius: 2rpx 0 0 2rpx;
}

.person-card:nth-child(4n+1)::after {
  background: linear-gradient(180deg, var(--primary-500), #764BA2);
}
.person-card:nth-child(4n+2)::after {
  background: linear-gradient(180deg, var(--secondary-500), #FB923C);
}
.person-card:nth-child(4n+3)::after {
  background: linear-gradient(180deg, #EC4899, #F093FB);
}
.person-card:nth-child(4n)::after {
  background: linear-gradient(180deg, #9C27B0, #E91E63);
}

.person-card:active {
  transform: scale(0.98);
  background: var(--glass-bg-hover);
}

/* 头像 */
.person-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.person-avatar.male {
  background: linear-gradient(135deg, var(--primary-500) 0%, #764BA2 100%);
}

.person-avatar.female {
  background: linear-gradient(135deg, #F093FB 0%, #EC4899 100%);
}

.avatar-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: #FFFFFF;
}

/* 人员信息 */
.person-info {
  flex: 1;
  min-width: 0;
}

.person-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.person-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--neutral-800);
}

.stable-badge {
  display: flex;
  align-items: center;
  background: rgba(16, 185, 129, 0.2);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  gap: 4rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.badge-icon {
  font-size: 18rpx;
  color: #10B981;
}

.badge-text {
  font-size: 20rpx;
  color: #10B981;
  font-weight: 500;
}

.person-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mini-tag {
  font-size: 20rpx;
  color: var(--neutral-500);
  background: rgba(255, 255, 255, 0.06);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.person-analysis {
  /* 分析信息 */
}

.current-type {
  display: block;
  font-size: var(--font-size-sm);
  color: #F59E0B;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.confidence-bar {
  height: 5rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.confidence-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-500) 0%, var(--secondary-500) 100%);
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
}

.confidence-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.confidence-text {
  font-size: var(--font-size-xs);
  color: var(--neutral-500);
}

.analysis-count {
  font-size: var(--font-size-xs);
  color: var(--neutral-400);
}

/* 箭头 */
.person-arrow {
  margin-left: var(--space-2);
  flex-shrink: 0;
}

.person-arrow text {
  font-size: 40rpx;
  color: var(--neutral-400);
  font-weight: 300;
}

/* ============================================
   空状态
   ============================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--space-4);
}

.empty-illustration {
  font-size: 120rpx;
  margin-bottom: var(--space-4);
  opacity: 0.4;
  filter: grayscale(0.5);
}

.empty-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--neutral-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-base);
  color: var(--neutral-500);
  text-align: center;
}
