<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-icon">
      <text>👥</text>
    </view>
    <text class="page-title">分析对象</text>
    <text class="page-subtitle">长期跟踪 · 置信度累积</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <view class="stat-icon blue">
        <text>👤</text>
      </view>
      <view class="stat-info">
        <text class="stat-num">{{persons.length}}</text>
        <text class="stat-label">总人数</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon green">
        <text>⭐</text>
      </view>
      <view class="stat-info">
        <text class="stat-num">{{stableCount}}</text>
        <text class="stat-label">已稳定</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon orange">
        <text>📊</text>
      </view>
      <view class="stat-info">
        <text class="stat-num">{{totalAnalyses}}</text>
        <text class="stat-label">总分析</text>
      </view>
    </view>
  </view>

  <!-- 人员列表 -->
  <view class="persons-list" wx:if="{{persons.length > 0}}">
    <view wx:for="{{persons}}" wx:key="index" class="person-card" bindtap="viewPersonDetail" data-person="{{item}}">
      <!-- 左侧头像 -->
      <view class="person-avatar {{item.gender === '女' ? 'female' : 'male'}}">
        <text class="avatar-text">{{item.name.charAt(0)}}</text>
      </view>

      <!-- 中间信息 -->
      <view class="person-info">
        <view class="person-header">
          <text class="person-name">{{item.name}}</text>
          <view class="stable-badge" wx:if="{{item.isStable}}">
            <text class="badge-icon">✓</text>
            <text class="badge-text">稳定</text>
          </view>
        </view>

        <view class="person-tags">
          <view class="mini-tag">{{item.recipientType}}</view>
          <view class="mini-tag">{{item.gender}}</view>
        </view>

        <view class="person-analysis">
          <text class="current-type">{{item.currentType || '待分析'}}</text>
          <view class="confidence-bar" wx:if="{{item.confidence > 0}}">
            <view class="confidence-fill" style="width: {{item.confidence}}%"></view>
          </view>
          <view class="confidence-row">
            <text class="confidence-text">{{item.confidence || 0}}% 置信度</text>
            <text class="analysis-count">分析 {{item.analysisCount || 0}} 次</text>
          </view>
        </view>
      </view>

      <!-- 右侧箭头 -->
      <view class="person-arrow">
        <text>›</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-illustration">👥</view>
    <text class="empty-title">暂无分析对象</text>
    <text class="empty-desc">去「分析」页面创建第一个分析对象吧</text>
  </view>
</view>