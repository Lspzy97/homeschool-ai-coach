/* ============================================
   会员中心 - 暗夜琉璃 / 星际奢华
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0A0E27 0%, #1A1F4E 40%, #2D1B4E 80%, #1A1033 100%);
  position: relative;
  padding-bottom: 60rpx;
}

/* 顶部装饰光球 */
.top-decoration {
  position: relative;
  height: 300rpx;
}

.decoration-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  pointer-events: none;
}

.decoration-orb.orb-1 {
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.4) 0%, transparent 70%);
}

.decoration-orb.orb-2 {
  top: 50rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 193, 7, 0.3) 0%, transparent 70%);
}

/* 页面标题 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}

.header-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 10rpx 30rpx rgba(255, 215, 0, 0.4));
}

.header-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-shadow:
    0 4rpx 20rpx rgba(255, 215, 0, 0.6),
    0 8rpx 40rpx rgba(255, 215, 0, 0.4);
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
}

/* 当前会员状态 - 奢金光效 */
.vip-status-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF2D92 100%);
  border-radius: 36rpx;
  padding: 40rpx;
  margin: 0 32rpx 36rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  box-shadow:
    0 30rpx 100rpx rgba(255, 107, 53, 0.3),
    0 0 0 1rpx rgba(255, 255, 255, 0.5) inset;
  position: relative;
  overflow: hidden;
}

.vip-status-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 50%);
  pointer-events: none;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 100rpx;
  padding: 10rpx 24rpx;
  margin-bottom: 24rpx;
}

.badge-icon {
  font-size: 28rpx;
}

.badge-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.status-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.status-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.vip-features {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.feature-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

/* 升级提示 */
.upgrade-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx 36rpx;
  gap: 16rpx;
}

.prompt-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.prompt-icon {
  font-size: 48rpx;
}

.prompt-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功能对比 */
.compare-section {
  padding: 0 32rpx;
  margin-bottom: 36rpx;
}

.compare-header {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.compare-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.compare-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.compare-card.vip {
  border: 3rpx solid #FF6B35;
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.2),
    0 0 40rpx rgba(255, 107, 53, 0.3);
}

.compare-card.vip.monthly {
  border: 3rpx solid rgba(255, 107, 53, 0.5);
}

.compare-card.vip.yearly {
  border: 3rpx solid #FF6B35;
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.2),
    0 0 60rpx rgba(255, 107, 53, 0.4);
  position: relative;
}

.compare-card.vip.permanent {
  border: 3rpx solid #9333EA;
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.2),
    0 0 60rpx rgba(147, 51, 234, 0.3);
}

.compare-card.vip.permanent .compare-card-header.vip {
  background: linear-gradient(135deg, #9333EA 0%, #7C3AED 100%);
}

.discount-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF2D92 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  z-index: 1;
}

/* 选中状态 */
.compare-card.selected {
  transform: scale(1.02);
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.25),
    0 0 80rpx rgba(255, 107, 53, 0.5);
}

.compare-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.compare-card-header.free {
  background: linear-gradient(135deg, rgba(229, 231, 235, 0.9), rgba(243, 244, 246, 0.9));
}

.compare-card-header.vip {
  background: linear-gradient(135deg, #FF6B35 0%, #FF2D92 100%);
}

.card-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
}

.card-price {
  font-size: 44rpx;
  font-weight: 900;
  color: #1F2937;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.card-price-unit {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.compare-list {
  padding: 24rpx 32rpx;
}

.compare-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.compare-item:last-child {
  border-bottom: none;
}

.compare-item.disabled {
  opacity: 0.5;
}

.item-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.item-text {
  font-size: 28rpx;
  color: #374151;
}

.item-text.highlight {
  font-weight: 600;
  color: #1F2937;
}

/* 开通按钮 */
.upgrade-btn-wrap {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.upgrade-btn {
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF2D92 100%);
  border-radius: 60rpx;
  padding: 28rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow:
    0 16rpx 48rpx rgba(255, 107, 53, 0.4),
    0 0 60rpx rgba(255, 107, 53, 0.15) inset;
  position: relative;
  overflow: hidden;
}

.upgrade-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 50%);
  pointer-events: none;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.or-text {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.or-text::before,
.or-text::after {
  content: '';
  width: 60rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
}

.or-text text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.wechat-copy {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--primary-500), #764BA2);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
  box-shadow: var(--shadow-glow);
}

.copy-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.wechat-id {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.copy-icon {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 账号信息卡片 */
.account-card {
  background: linear-gradient(145deg, rgba(102, 126, 234, 0.3), rgba(118, 75, 162, 0.2));
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 36rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.account-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.account-icon {
  font-size: 36rpx;
}

.account-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.account-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  font-family: monospace;
  letter-spacing: 1rpx;
}

.info-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.account-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}

/* 已开通用户说明 */
.vip-user-guide {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 36rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow-sm);
}

.guide-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--neutral-800);
  margin-bottom: 24rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.guide-steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--primary-500), #764BA2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #FFFFFF;
  flex-shrink: 0;
  box-shadow: var(--shadow-glow);
}

.step-text {
  font-size: 28rpx;
  color: var(--neutral-600);
  line-height: 1.5;
}

/* 安全提示 */
.safe-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 32rpx;
}

.safe-icon {
  font-size: 24rpx;
}

.safe-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 底部留白 */
.bottom-space {
  height: 60rpx;
}

/* 登录提示 */
.login-tip-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  margin: 0 32rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.tip-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.tip-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
}

.login-btn {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  padding: 24rpx 60rpx;
  border-radius: 48rpx;
}

.login-btn .btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 复制区域 */
.copy-section {
  padding: 24rpx 32rpx 48rpx;
  display: flex;
  justify-content: center;
}

.copy-content {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
}

.copy-label {
  font-size: 26rpx;
  color: #6B7280;
  letter-spacing: 2rpx;
}

.copy-wechat-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
}

.wechat-id {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}

.copy-icon {
  font-size: 28rpx;
  opacity: 0.9;
}
