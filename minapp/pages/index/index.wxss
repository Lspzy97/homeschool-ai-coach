/* ============================================
   首页 - 星际科幻设计 v7
   高级3D渲染版 · 沉浸式立体效果
   ============================================ */

page {
  --primary-500: #667EEA;
  --primary-600: #764BA2;
  --secondary-500: #F59E0B;
  --success: #10B981;
  --neutral-100: #F3F4F6;
  --neutral-200: #E5E7EB;
  --neutral-300: #D1D5DB;
  --neutral-400: #9CA3AF;
  --neutral-500: #6B7280;
  --neutral-600: #757575;
  --neutral-700: #374151;
  --neutral-800: #1F2937;
  --neutral-900: #111827;
}

/* ============================================
   基础容器 - 3D场景设置
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0A0E27 0%, #1A1F4E 40%, #2D1B4E 80%, #1A1033 100%);
  position: relative;
}

