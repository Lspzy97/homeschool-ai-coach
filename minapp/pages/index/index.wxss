    radial-gradient(2rpx 2rpx at 29% 17%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 41% 83%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 53% 50%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 27%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 77% 67%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 89% 47%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 97% 87%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 13% 93%, rgba(255,255,255,0.5) 0%, transparent 100%),
