   ============================================ */

.result-section {
  animation: resultSlideUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform-style: preserve-3d;
}

@keyframes resultSlideUp {
  from {
    opacity: 0;
    transform: translateY(80rpx) scale(0.92) rotateX(10deg);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1) rotateX(0deg);
  }
}

