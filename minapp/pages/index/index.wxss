/* ============================================
   分析按钮 - 高级3D效果
   ============================================ */

.analyze-btn-wrap {
  margin-bottom: 32rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
}

.analyze-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 110rpx;
  background: linear-gradient(145deg, #667EEA 0%, #764BA2 50%, #EC4899 100%);
  border-radius: 55rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow:
    0 24rpx 80rpx rgba(102, 126, 234, 0.4),
    0 0 60rpx rgba(102, 126, 234, 0.2) inset,
    inset 0 3rpx 0 rgba(255, 255, 255, 0.25);
}

/* 3D边框光效 */
.analyze-btn::before {
  content: '';
  position: absolute;
  inset: -3rpx;
  border-radius: 68rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2, #EC4899, #F093FB, #667EEA);
  background-size: 400% 400%;
  animation: borderGlow 2.5s ease infinite;
  z-index: -1;
  filter: blur(3rpx);
  opacity: 0.7;
}

/* 流光动画 */
.analyze-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -150%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4) 50%, transparent);
  animation: btnShimmer 2.5s infinite;
}

@keyframes btnShimmer {
  0% { left: -150%; }
  100% { left: 150%; }
}

.analyze-btn:active {
  transform: scale(0.96) translateZ(25rpx);
  box-shadow:
    0 20rpx 60rpx rgba(102, 126, 234, 0.45),
    0 0 80rpx rgba(102, 126, 234, 0.25) inset;
}

.analyze-btn.loading {
  background: linear-gradient(145deg, #9CA3AF 0%, #6B7280 100%);
  box-shadow: none;
}

.analyze-btn.loading::before,
.analyze-btn.loading::after {
  display: none;
}

.btn-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.btn-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================
