  box-shadow:
    0 10rpx 32rpx rgba(0, 0, 0, 0.08),
    0 0 20rpx rgba(102, 126, 234, 0.05) inset;
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform-style: preserve-3d;
}

.reply-item:active {
  transform: translateX(10rpx) translateZ(5rpx);
}

.reply-header {
  margin-bottom: 16rpx;
}

.reply-label {
  font-size: 26rpx;
  color: #667EEA;
  font-weight: 800;
  background: linear-gradient(145deg, #EEF2FF 0%, #E0E7FF 100%);
  padding: 10rpx 24rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  display: inline-block;
}

.reply-text {
  display: block;
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.7;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.copy-btn {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  background: linear-gradient(145deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 800;
  padding: 16rpx 36rpx;
  border-radius: 32rpx;
  box-shadow:
    0 10rpx 32rpx rgba(102, 126, 234, 0.4),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
  transform-style: preserve-3d;
}

.copy-btn:active {
  transform: scale(0.95) translateZ(-3rpx);
}

/* 指引卡片 - 紫色3D效果 */
.guide-card {
  background: linear-gradient(145deg, #EEF2FF 0%, #DDD6FE 100%);
  border: 3rpx solid rgba(102, 126, 234, 0.4);
  box-shadow:
    0 30rpx 100rpx rgba(102, 126, 234, 0.25),
    0 0 0 1rpx rgba(255, 255, 255, 0.6) inset,
    0 0 100rpx rgba(102, 126, 234, 0.15) inset;
}

.guide-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.guide-icon {
  font-size: 72rpx;
  filter: drop-shadow(0 6rpx 20rpx rgba(0, 0, 0, 0.15));
  transform: translateZ(10rpx);
}

.guide-info {
  flex: 1;
}

.guide-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #4338CA;
  margin-bottom: 10rpx;
}

.guide-subtitle {
  display: block;
  font-size: 28rpx;
  color: #6366F1;
}

.guide-content {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.guide-section {
  margin-bottom: 24rpx;
}

.guide-section:last-child {
  margin-bottom: 0;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #4F46E5;
  margin-bottom: 16rpx;
}

.strength-list, .suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.strength-item, .suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.strength-dot {
  font-size: 36rpx;
  color: #6366F1;
}

.strength-text, .sug-text {
  flex: 1;
  font-size: 30rpx;
  color: #4338CA;
  line-height: 1.7;
}

.sug-num {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(145deg, #6366F1 0%, #4F46E5 100%);
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow:
    0 8rpx 24rpx rgba(99, 102, 241, 0.4),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
  transform: translateZ(5rpx);
}

/* 预警卡片 */
.warning-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  background: linear-gradient(145deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 32rpx;
  padding: 36rpx;
  border: 3rpx solid rgba(251, 191, 36, 0.4);
  box-shadow:
    0 20rpx 60rpx rgba(251, 191, 36, 0.25),
    0 0 40rpx rgba(251, 191, 36, 0.1) inset;
}

.warning-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 16rpx rgba(0, 0, 0, 0.15));
  transform: translateZ(5rpx);
}

.warning-content {
  flex: 1;
}

.warning-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #92400E;
  margin-bottom: 12rpx;
}

.warning-text {
  display: block;
  font-size: 30rpx;
  color: #78350F;
  line-height: 1.7;
}

/* ============================================
   人员选择弹窗 - 3D抽屉效果
   ============================================ */

.person-picker-modal {
  position: fixed;
  inset: 0;
  background: rgba(10, 14, 39, 0.94);
  backdrop-filter: blur(24rpx);
  display: flex;
  align-items: flex-end;
  z-index: 200;
  animation: fadeIn 0.35s ease;
  perspective: 1200rpx;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.picker-sheet {
  width: 100%;
  max-height: 85vh;
  background: linear-gradient(180deg, #FFFFFF 0%, #F9FAFB 100%);
  border-radius: 48rpx 48rpx 0 0;
  animation: slideUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  transform-style: preserve-3d;
  box-shadow: 0 -20rpx 100rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

/* 顶部光泽 */
.picker-sheet::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, rgba(102, 126, 234, 0.1) 0%, transparent 100%);
  pointer-events: none;
}

@keyframes slideUp {
  from {
    transform: translateY(100%) rotateX(-15deg);
    opacity: 0;
  }
  to {
    transform: translateY(0) rotateX(0deg);
    opacity: 1;
  }
}

.sheet-handle {
  width: 100rpx;
  height: 12rpx;
  background: linear-gradient(90deg, #667EEA, #764BA2, #EC4899);
  border-radius: 6rpx;
  margin: 32rpx auto;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
  position: relative;
  z-index: 1;
}

.picker-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1F2937;
  letter-spacing: 4rpx;
}

.close-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #9CA3AF;
  background: linear-gradient(145deg, #F3F4F6 0%, #E5E7EB 100%);
  border-radius: 50%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  transition: all 0.25s ease;
  transform-style: preserve-3d;
}

.close-btn:active {
  transform: scale(0.9) rotate(90deg);
}

.picker-body {
  padding: 36rpx 40rpx;
  max-height: 65vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.create-btn, .random-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  margin-bottom: 22rpx;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
}

.create-btn {
  background: linear-gradient(145deg, #667EEA 0%, #764BA2 100%);
  box-shadow:
    0 20rpx 60rpx rgba(102, 126, 234, 0.5),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.25);
}

.random-btn {
  background: linear-gradient(145deg, #F59E0B 0%, #FB923C 100%);
  box-shadow:
    0 20rpx 60rpx rgba(245, 158, 11, 0.5),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.25);
}

.create-btn:active, .random-btn:active {
  transform: scale(0.97) translateZ(5rpx);
}

.create-btn .btn-icon, .random-btn .btn-icon {
  font-size: 44rpx;
  color: #FFFFFF;
}

.create-btn .btn-text, .random-btn .btn-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}

.empty-hint {
  text-align: center;
  padding: 120rpx;
  font-size: 30rpx;
  color: #9CA3AF;
}

.person-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  padding: 32rpx;
  background: linear-gradient(145deg, #F9FAFB 0%, #F3F4F6 100%);
  border-radius: 28rpx;
  margin-bottom: 18rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.person-item:active {
  transform: scale(0.98) translateZ(5rpx);
}

.person-item.selected {
  border-color: #667EEA;
  background: linear-gradient(145deg, #EEF2FF 0%, #E0E7FF 100%);
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.3);
}

.avatar-sm {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  flex-shrink: 0;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  transform: translateZ(10rpx);
}

.avatar-sm.male {
  background: linear-gradient(145deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
}

.avatar-sm.female {
  background: linear-gradient(145deg, #F093FB 0%, #EC4899 100%);
  color: #FFFFFF;
}

.person-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.person-name {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #1F2937;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.person-meta {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.person-type {
  text-align: center;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.type-text {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #F59E0B;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.confidence-text {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  white-space: nowrap;
}

/* VIP专属卡片样式 */
.vip-card {
  background: linear-gradient(145deg, #7C3AED 0%, #6D28D9 50%, #5B21B6 100%);
  border: 3rpx solid rgba(167, 139, 250, 0.5);
  box-shadow:
    0 30rpx 100rpx rgba(124, 58, 237, 0.35),
    0 0 0 1rpx rgba(255, 255, 255, 0.15) inset,
    0 0 100rpx rgba(124, 58, 237, 0.2) inset;
  position: relative;
  overflow: hidden;
}

.vip-card::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  filter: blur(40rpx);
  pointer-events: none;
}

.vip-card .result-header {
  position: relative;
  z-index: 1;
}

.vip-card .result-title {
  color: #FFFFFF;
}

.vip-card .result-emoji {
  filter: drop-shadow(0 4rpx 12rpx rgba(255, 255, 255, 0.3));
}

.vip-badge {
  background: linear-gradient(145deg, #FBBF24 0%, #F59E0B 100%);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #78350F;
  box-shadow:
    0 6rpx 20rpx rgba(251, 191, 36, 0.4),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
}

.vip-content {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 28rpx;
  position: relative;
  z-index: 1;
}

.vip-text {
  display: block;
  font-size: 30rpx;
  color: #FFFFFF;
  line-height: 1.7;
}

/* 右上角使用小贴士按钮 */
.help-tip-btn {
  position: fixed;
  top: 40rpx;
  right: 30rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.help-tip-btn text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.help-tip-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.35);
}

/* 贴士弹窗 */
.help-modal {
  position: fixed;
  inset: 0;
  background: rgba(10, 14, 39, 0.85);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 300;
  animation: fadeIn 0.3s ease;
}

.help-content {
  background: linear-gradient(145deg, #1A1F4E 0%, #2D1B4E 100%);
  border-radius: 36rpx;
  padding: 40rpx;
  max-width: 600rpx;
  width: 90%;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 30rpx 100rpx rgba(0, 0, 0, 0.5);
}

.help-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.help-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.help-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
}

.help-close:active {
  transform: scale(0.9);
}

.help-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.help-step {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(145deg, #667EEA 0%, #764BA2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #FFFFFF;
  flex-shrink: 0;
}

.step-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  padding-top: 8rpx;
}

.help-benefit {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(102, 126, 234, 0.2);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.help-benefit text {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1.5;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
