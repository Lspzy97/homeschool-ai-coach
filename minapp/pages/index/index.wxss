@keyframes starfieldDrift {
  0% { transform: translateY(0) scale(1) rotate(0deg); opacity: 0.6; }
  25% { opacity: 0.9; }
  50% { transform: translateY(-50rpx) scale(1.1) rotate(2deg); opacity: 0.75; }
  75% { opacity: 1; }
  100% { transform: translateY(0) scale(1) rotate(0deg); opacity: 0.6; }
}

/* ============================================
   Hero 头部 - 沉浸式3D效果
   ============================================ */

.hero-section {
  position: relative;
  padding: 100rpx 32rpx 160rpx;
  background: linear-gradient(180deg, #1A1F4E 0%, #2D1B4E 50%, rgba(10, 14, 39, 0) 100%);
  text-align: center;
  overflow: hidden;
}

/* 3D光球效果 */
.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.4) 0%, rgba(118, 75, 162, 0.2) 40%, transparent 70%);
  filter: blur(60rpx);
  animation: orbFloat 6s ease-in-out infinite;
  pointer-events: none;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -50rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 200rpx;
  background: radial-gradient(ellipse, rgba(236, 72, 153, 0.3) 0%, transparent 70%);
  filter: blur(40rpx);
  animation: orbFloat 8s ease-in-out infinite reverse;
  pointer-events: none;
}

@keyframes orbFloat {
  0%, 100% { transform: translateX(-50%) translateY(0) scale(1); }
  50% { transform: translateX(-50%) translateY(-30rpx) scale(1.1); }
}

/* 背景星光效果 */
.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.hero-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(255,255,255,0.8) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 50% 50%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 80% 70%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 10% 60%, rgba(255,255,255,0.7) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 90% 20%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(3rpx 3rpx at 40% 80%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 60% 10%, rgba(255,255,255,0.5) 0%, transparent 100%);
  animation: starTwinkle 4s ease-in-out infinite;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform-style: preserve-3d;
}

.hero-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(102, 126, 234, 0.35);
  backdrop-filter: blur(20rpx);
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow:
    0 8rpx 32rpx rgba(102, 126, 234, 0.3),
    0 0 40rpx rgba(102, 126, 234, 0.15) inset;
}

@keyframes badgeFloat {
  0%, 100% { transform: translateY(0) rotateX(0deg); }
  50% { transform: translateY(-12rpx) rotateX(5deg); }
}

.badge-icon {
  font-size: 26rpx;
}

.badge-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 3rpx;
}

/* 3D图标容器 */
.hero-icon-wrapper {
  position: relative;
  transform-style: preserve-3d;
  margin-bottom: 36rpx;
}

/* 3D光圈 */
.hero-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(102, 126, 234, 0.3);
  animation: ringRotate 8s linear infinite;
}

.hero-icon-wrapper::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(236, 72, 153, 0.3);
  animation: ringRotate 12s linear infinite reverse;
}

@keyframes ringRotate {
  0% { transform: translate(-50%, -50%) rotateZ(0deg); }
  100% { transform: translate(-50%, -50%) rotateZ(360deg); }
}

.hero-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(145deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  position: relative;
  transform-style: preserve-3d;
  animation: iconFloat 4s ease-in-out infinite;
  box-shadow:
    0 40rpx 100rpx rgba(0, 0, 0, 0.4),
    0 0 80rpx rgba(102, 126, 234, 0.3) inset;
}

.hero-icon::before {
  content: '';
  position: absolute;
  inset: -8rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2, #EC4899, #F093FB, #667EEA);
  background-size: 400% 400%;
  animation: borderGlow 3s ease infinite;
  z-index: -1;
  filter: blur(2rpx);
  opacity: 0.8;
}

.hero-icon::after {
  content: '';
  position: absolute;
  inset: -16rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(236, 72, 153, 0.2));
  filter: blur(20rpx);
  z-index: -2;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes iconFloat {
  0%, 100% { transform: translateZ(50rpx) translateY(0); }
  50% { transform: translateZ(50rpx) translateY(-20rpx); }
}

@keyframes borderGlow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
  text-shadow:
    0 4rpx 20rpx rgba(102, 126, 234, 0.6),
    0 8rpx 40rpx rgba(102, 126, 234, 0.3);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
}

/* ============================================
   主要内容区 - 卡片3D层叠
   ============================================ */

.main-content {
  padding: 0 32rpx 60rpx;
  margin-top: -100rpx;
  position: relative;
  z-index: 3;
  transform-style: preserve-3d;
}

/* ============================================
   状态横幅 - 玻璃态3D效果
   ============================================ */

.status-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 36rpx;
  border-radius: 28rpx;
  margin-bottom: 36rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  backdrop-filter: blur(24rpx);
  transform-style: preserve-3d;
  position: relative;
}

.status-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 28rpx;
  padding: 2rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.4), transparent);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.status-banner.warning {
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.95) 0%, rgba(253, 230, 138, 0.9) 100%);
  box-shadow:
    0 16rpx 48rpx rgba(251, 191, 36, 0.3),
    0 0 40rpx rgba(251, 191, 36, 0.15) inset;
}

.status-banner.success {
  background: linear-gradient(135deg, rgba(209, 250, 229, 0.95) 0%, rgba(167, 243, 208, 0.9) 100%);
  box-shadow:
    0 16rpx 48rpx rgba(16, 185, 129, 0.3),
    0 0 40rpx rgba(16, 185, 129, 0.15) inset;
}

.status-icon {
  font-size: 40rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.status-text {
  font-size: 30rpx;
  font-weight: 700;
}

.status-banner.warning .status-text {
  color: #92400E;
}

.status-banner.success .status-text {
  color: #065F46;
}

/* 情直理论入口 */
.theory-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
  border-radius: 40rpx;
  margin-bottom: 28rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  transition: all 0.3s ease;
}

.theory-link:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.15);
}

.link-icon {
  font-size: 26rpx;
}

.link-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* ============================================
   输入区域 - 3D玻璃卡片
   ============================================ */

.input-section {
  margin-bottom: 36rpx;
  transform-style: preserve-3d;
}

.input-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.3s ease;
  box-shadow:
    0 24rpx 80rpx rgba(0, 0, 0, 0.25),
    0 0 0 1rpx rgba(255, 255, 255, 0.6) inset;
}

/* 3D顶部边框光效 */
.input-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667EEA, #764BA2, #EC4899, #F093FB, #667EEA);
  background-size: 300% 100%;
  border-radius: 36rpx 36rpx 0 0;
  animation: gradientFlow 2.5s ease infinite;
}

.input-card::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(102, 126, 234, 0.1) 0%, transparent 30%);
  pointer-events: none;
}

@keyframes gradientFlow {
  0% { background-position: 0% 0%; }
  50% { background-position: 100% 0%; }
  100% { background-position: 0% 0%; }
}

.input-card:active {
  transform: scale(0.98) translateZ(10rpx);
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.25),
    0 0 0 1rpx rgba(255, 255, 255, 0.8) inset;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.label-icon {
  font-size: 48rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.15));
}

.label-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #1F2937;
  letter-spacing: 3rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(145deg, #F9FAFB 0%, #E5E7EB 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
