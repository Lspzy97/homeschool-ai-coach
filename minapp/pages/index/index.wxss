/* ============================================
   分析对象选择器 - 高级3D卡片
   ============================================ */

.person-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.97);
  border-radius: 32rpx;
  padding: 36rpx;
